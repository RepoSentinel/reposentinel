DATABASE_URL=postgresql://mergesignal:mergesignal@localhost:5433/mergesignal
REDIS_URL=redis://localhost:6379
PORT=4000

MERGESIGNAL_AUTO_MIGRATE=1

# Public web origin for legal links in OpenAPI (defaults to Fly web if unset).
# MERGESIGNAL_WEB_APP_URL=https://mergesignal-web.fly.dev

# Include the Fly web origin when using https://mergesignal-web.fly.dev ; keep localhost for local dev.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://mergesignal-web.fly.dev

MERGESIGNAL_ENGINE_IMPL=
MERGESIGNAL_ENGINE_STRICT=0

FREE_SCANS_PER_OWNER_PER_DAY=25
FREE_GITHUB_SCANS_PER_OWNER_PER_DAY=15
FREE_SCAN_MAX_LOCKFILE_BYTES=1000000

PAID_SCANS_PER_OWNER_PER_DAY=-1
PAID_GITHUB_SCANS_PER_OWNER_PER_DAY=-1
PAID_SCAN_MAX_LOCKFILE_BYTES=5000000

MERGESIGNAL_DEFAULT_TIER=free
MERGESIGNAL_OWNER_TIERS=

GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=
GITHUB_WEBHOOK_SECRET=

# Optional error reporting (API)
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.05

CODE_ANALYSIS_TIMEOUT_MS=30000
CODE_ANALYSIS_CACHE_TTL_MS=86400000
