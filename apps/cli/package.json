{
  "name": "@reposentinel/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "reposentinel": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node --enable-source-maps dist/cli.js",
    "check-types": "tsc -p tsconfig.json --noEmit",
    "lint": "echo 'No lint configured for CLI'",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@reposentinel/engine": "workspace:^",
    "@reposentinel/shared": "workspace:^"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.8"
  }
}
