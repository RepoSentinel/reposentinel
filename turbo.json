{
  "$schema": "https://turborepo.dev/schema.json",
  "ui": "tui",
  "globalEnv": [
    "NODE_ENV",
    "PORT",
    "HOST",
    "LOG_LEVEL",
    "DATABASE_URL",
    "REDIS_URL",
    "CORS_ORIGINS",
    "INIT_CWD",
    "MERGESIGNAL_AUTO_MIGRATE",
    "MERGESIGNAL_OWNER_TIERS",
    "MERGESIGNAL_DEFAULT_TIER",
    "RATE_LIMIT_PUBLIC",
    "RATE_LIMIT_AUTHENTICATED",
    "SIMULATE_MAX_LOCKFILE_BYTES",
    "FREE_SCAN_MAX_LOCKFILE_BYTES",
    "FREE_SCANS_PER_OWNER_PER_DAY",
    "FREE_GITHUB_SCANS_PER_OWNER_PER_DAY",
    "FREE_PR_COMMENTS_ENABLED",
    "FREE_ALERTS_ENABLED",
    "PAID_SCAN_MAX_LOCKFILE_BYTES",
    "PAID_SCANS_PER_OWNER_PER_DAY",
    "PAID_GITHUB_SCANS_PER_OWNER_PER_DAY",
    "GITHUB_APP_ID",
    "GITHUB_PRIVATE_KEY",
    "GITHUB_WEBHOOK_SECRET",
    "NEXT_PUBLIC_API_BASE_URL",
    "NEXT_PUBLIC_API_KEY"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", ".env*"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**"]
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "check-types": {
      "dependsOn": ["^check-types"]
    },
    "test": {
      "dependsOn": ["^test"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
