{
  "name": "mergesignal",
  "private": true,
  "description": "Security analysis platform for npm dependencies",
  "version": "0.1.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "mergesignal": "pnpm -C apps/cli exec -- tsx src/cli.ts",
    "ms": "pnpm -C apps/cli exec -- tsx src/cli.ts"
  },
  "devDependencies": {
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.4.2",
    "turbo": "^2.8.11",
    "typescript": "5.9.2",
    "dotenv": "^16.4.5"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=20.19"
  }
}
